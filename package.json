{
  "name": "wine-sock",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,blue \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/client\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace=apps/server",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/server",
    "db:seed": "npm run db:seed --workspace=apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
